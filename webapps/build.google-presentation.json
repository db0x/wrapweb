{
    "profile": "google-presentation",
    "name": "Google Presentation",
    "icon": "google-slides",
    "url": "https://slides.google.com",
    "routingUrls": ["https://docs.google.com/presentation"],
    "category": "google",
    "acceptsFileArg": true,
    "plugins": ["plugins/rclone-sync/rclone-sync.js"],
    "rcloneEditUrlBase": "https://docs.google.com/presentation/d",
    "mimeTypes": ["application/vnd.openxmlformats-officedocument.presentationml.presentation"],
    "mimeExtensions": {
        "application/vnd.openxmlformats-officedocument.presentationml.presentation": ["pptx"]
    },
    "mimeIcons": {
        "application/vnd.openxmlformats-officedocument.presentationml.presentation": "application-google-slides.svg"
    }
}
