{
    "profile": "google-docs",
    "name": "Google Docs",
    "icon": "google-docs",
    "url": "https://docs.google.com",
    "category": "google",
    "acceptsFileArg": true,
    "plugins": ["plugins/rclone-sync/rclone-sync.js"],
    "rcloneEditUrlBase": "https://docs.google.com/document/d",
    "mimeTypes": ["application/vnd.openxmlformats-officedocument.wordprocessingml.document"],
    "mimeExtensions": {
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document": ["docx"]
    },
    "mimeIcons": {
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document": "application-google-docs.svg"
    }
}